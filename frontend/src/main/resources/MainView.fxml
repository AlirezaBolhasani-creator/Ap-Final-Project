<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.aut.frontend.controller.MainViewController"
            stylesheets="@theme.css">

    <!-- ═══════════════════  TOP NAV BAR  ═══════════════════ -->
    <top>
        <VBox>

            <!-- Primary navbar -->
            <HBox styleClass="app-nav" alignment="CENTER_LEFT" spacing="8">

                <Label text="دیوار" styleClass="brand-logo"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Search -->
                <HBox styleClass="input-icon" alignment="CENTER" spacing="8" minWidth="360">
                    <FontIcon iconLiteral="fas-search" iconSize="16" iconColor="#6b7ba3"/>
                    <TextField fx:id="searchField"
                               promptText="جستجو در همه آگهی‌ها…"
                               onAction="#applyFilter"
                               HBox.hgrow="ALWAYS"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Nav actions -->
                <HBox spacing="4" alignment="CENTER">
                    <Button fx:id="myAdsBtn" text="دیوار من" styleClass="btn btn-ghost" onAction="#onMyAds"/>
                    <StackPane>
                        <Button text="گفتگوها" styleClass="btn btn-ghost" onAction="#onConversations"/>
                        <Label fx:id="chatBadge" styleClass="nav-badge" visible="false" managed="false"
                               StackPane.alignment="TOP_LEFT"/>
                    </StackPane>
                    <Button text="علاقه‌مندی‌ها" styleClass="btn btn-ghost" onAction="#onFavorites"/>
                    <Button fx:id="adminPanelBtn" text="پنل مدیریت" styleClass="btn btn-ghost" onAction="#onAdminPanel"/>
                    <Button fx:id="themeToggleBtn" text="حالت روشن" styleClass="btn btn-outline theme-toggle-btn" onAction="#onToggleTheme"/>
                    <Button text="خروج" styleClass="btn btn-ghost" onAction="#onLogout">
                        <graphic>
                            <FontIcon iconLiteral="fas-sign-out-alt" iconSize="15" iconColor="#a9b8de"/>
                        </graphic>
                    </Button>
                    <Button text="ثبت آگهی" styleClass="btn btn-primary" onAction="#onPostAd">
                        <graphic>
                            <FontIcon iconLiteral="fas-plus" iconSize="14" iconColor="#ffffff"/>
                        </graphic>
                    </Button>
                </HBox>

            </HBox>

            <!-- Category chips bar -->
            <HBox fx:id="categoryBar" styleClass="chip-bar" alignment="CENTER_RIGHT" spacing="8">
                <Label text="دسته‌ها" styleClass="text-small"/>
            </HBox>

        </VBox>
    </top>

    <!-- ═══════════════════  MAIN CONTENT  ═══════════════════ -->
    <center>
        <HBox spacing="0" alignment="TOP_RIGHT">

            <!-- ───── Ads area (scrollable) ───── -->
            <ScrollPane fx:id="adScrollPane"
                        fitToWidth="true"
                        HBox.hgrow="ALWAYS">

                <VBox spacing="0" styleClass="ads-container">

                    <!-- Hero header -->
                    <VBox styleClass="hero" spacing="14" alignment="CENTER_RIGHT">
                        <Label text="هرچی بخوای، نزدیکته" styleClass="text-display"/>
                        <Label text="میان هزاران آگهی تاییدشده در شهر خودت جستجو کن — از موبایل و ماشین تا خانه و کار."
                               styleClass="hero-sub" wrapText="true"/>
                        <HBox spacing="18" alignment="CENTER_RIGHT">
                            <HBox spacing="8" alignment="CENTER">
                                <FontIcon iconLiteral="fas-shield-alt" iconSize="16" iconColor="#34d399"/>
                                <Label text="آگهی‌های تاییدشده" styleClass="text-small"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER">
                                <FontIcon iconLiteral="fas-comments" iconSize="16" iconColor="#6b93ff"/>
                                <Label text="گفتگوی مستقیم با فروشنده" styleClass="text-small"/>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER">
                                <FontIcon iconLiteral="fas-map-marker-alt" iconSize="16" iconColor="#fbbf24"/>
                                <Label text="فیلتر بر اساس شهر و قیمت" styleClass="text-small"/>
                            </HBox>
                        </HBox>
                    </VBox>

                    <!-- Section header -->
                    <HBox alignment="CENTER_RIGHT" styleClass="section-header">
                        <Label text="جدیدترین آگهی‌ها" styleClass="text-h2"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ComboBox fx:id="sortCombo" promptText="مرتب‌سازی"/>
                    </HBox>

                    <!-- Ad grid -->
                    <FlowPane fx:id="adGrid"
                              hgap="20"
                              vgap="20"
                              prefWrapLength="820">
                        <!-- AdCards are injected programmatically in MainViewController -->
                    </FlowPane>

                </VBox>
            </ScrollPane>

            <!-- ───── Filters sidebar ───── -->
            <VBox styleClass="filter-sidebar" spacing="16" minWidth="260" maxWidth="260">

                <VBox styleClass="card" spacing="10">
                    <HBox alignment="CENTER_RIGHT" spacing="8">
                        <FontIcon iconLiteral="fas-map-marker-alt" iconSize="15" iconColor="#6b93ff"/>
                        <Label text="شهر" styleClass="text-h3"/>
                    </HBox>
                    <ComboBox fx:id="cityCombo" promptText="همه شهرها" maxWidth="Infinity" onAction="#applyFilter"/>
                </VBox>

                <VBox styleClass="card" spacing="12">
                    <HBox alignment="CENTER_RIGHT" spacing="8">
                        <FontIcon iconLiteral="fas-tag" iconSize="15" iconColor="#34d399"/>
                        <Label text="قیمت (تومان)" styleClass="text-h3"/>
                    </HBox>
                    <TextField fx:id="minPriceField" promptText="از" onAction="#applyFilter"/>
                    <TextField fx:id="maxPriceField" promptText="تا" onAction="#applyFilter"/>
                    <Button text="اعمال فیلتر" styleClass="btn btn-primary" maxWidth="Infinity" onAction="#applyFilter"/>
                </VBox>

                <VBox styleClass="card" spacing="10">
                    <HBox alignment="CENTER_RIGHT" spacing="8">
                        <FontIcon iconLiteral="fas-box-open" iconSize="15" iconColor="#fbbf24"/>
                        <Label text="وضعیت کالا" styleClass="text-h3"/>
                    </HBox>
                    <ComboBox fx:id="conditionCombo" promptText="همه وضعیت‌ها" maxWidth="Infinity" onAction="#applyFilter"/>
                </VBox>

            </VBox>

        </HBox>
    </center>

    <!-- ═══════════════════  STATUS BAR  ═══════════════════ -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="12">
            <FontIcon iconLiteral="fas-circle" iconSize="7" iconColor="#34d399"/>
            <Label fx:id="statusLabel" text="آماده" styleClass="text-caption"/>
        </HBox>
    </bottom>

</BorderPane>
