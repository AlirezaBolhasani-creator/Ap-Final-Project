<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane fitToWidth="true" nodeOrientation="RIGHT_TO_LEFT"
            stylesheets="@theme.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.aut.frontend.controller.PostAdController">

    <VBox spacing="22" styleClass="form-page">

        <!-- Header -->
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <StackPane styleClass="form-title-icon">
                <FontIcon iconLiteral="fas-plus-circle" iconSize="22" iconColor="#6b93ff"/>
            </StackPane>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="ثبت آگهی جدید" styleClass="text-h1"/>
                <Label text="اطلاعات کالا یا خدمت خود را وارد کنید تا آگهی‌ات دیده شود" styleClass="text-small"/>
            </VBox>
            <Button onAction="#handleBack" styleClass="btn-ouline" text="بازگشت">
                <graphic><FontIcon iconLiteral="fas-arrow-right" iconSize="14" iconColor="#a9b8de"/></graphic>
            </Button>
            <Button fx:id="clearBtn" onAction="#handleClear" styleClass="btn-outline" text="پاک کردن">
                <graphic><FontIcon iconLiteral="fas-redo" iconSize="14" iconColor="#a9b8de"/></graphic>
            </Button>
        </HBox>

        <!-- Images card -->
        <VBox styleClass="form-card" spacing="12">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <FontIcon iconLiteral="fas-images" iconSize="16" iconColor="#6b93ff"/>
                <Label text="عکس‌های آگهی" styleClass="text-h3"/>
            </HBox>
            <Label text="چند عکس بگذار تا آگهی‌ات بهتر دیده شود" styleClass="text-caption"/>
            <StackPane fx:id="imageUploadBox" styleClass="upload-box"
                       maxWidth="150" minHeight="150" minWidth="150"
                       onMouseClicked="#handleImageUpload">
                <VBox alignment="CENTER" spacing="8">
                    <FontIcon iconLiteral="fas-cloud-upload-alt" iconSize="34" iconColor="#6b93ff"/>
                    <Label text="افزودن عکس" styleClass="text-small"/>
                </VBox>
            </StackPane>
        </VBox>

        <!-- Details card -->
        <VBox styleClass="form-card" spacing="16">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <FontIcon iconLiteral="fas-align-right" iconSize="16" iconColor="#6b93ff"/>
                <Label text="جزئیات آگهی" styleClass="text-h3"/>
            </HBox>

            <VBox spacing="6">
                <HBox spacing="3">
                    <Label text="عنوان آگهی" styleClass="form-label"/>
                    <Label text="*" styleClass="form-req"/>
                </HBox>
                <TextField fx:id="titleField" promptText="عنوان آگهی خود را بنویسید"/>
            </VBox>

            <VBox spacing="6">
                <HBox spacing="3">
                    <Label text="توضیحات آگهی" styleClass="form-label"/>
                    <Label text="*" styleClass="form-req"/>
                </HBox>
                <TextArea fx:id="descriptionArea" prefRowCount="4"
                          promptText="توضیحات مربوط به آگهی را بنویسید"/>
            </VBox>
        </VBox>

        <!-- Pricing & place card -->
        <VBox styleClass="form-card" spacing="16">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <FontIcon iconLiteral="fas-tag" iconSize="16" iconColor="#34d399"/>
                <Label text="قیمت و مشخصات" styleClass="text-h3"/>
            </HBox>

            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <HBox spacing="3">
                        <Label text="قیمت (تومان)" styleClass="form-label"/>
                        <Label text="*" styleClass="form-req"/>
                    </HBox>
                    <TextField fx:id="priceField" promptText="مثلا: 150000"/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <HBox spacing="3">
                        <Label text="شهر" styleClass="form-label"/>
                        <Label text="*" styleClass="form-req"/>
                    </HBox>
                    <ComboBox fx:id="locationCombo" maxWidth="Infinity" promptText="انتخاب شهر..."/>
                </VBox>
            </HBox>

            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <HBox spacing="3">
                        <Label text="دسته‌بندی" styleClass="form-label"/>
                        <Label text="*" styleClass="form-req"/>
                    </HBox>
                    <ComboBox fx:id="categoryCombo" maxWidth="Infinity" promptText="انتخاب کنید..."/>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <HBox spacing="3">
                        <Label text="وضعیت کالا" styleClass="form-label"/>
                    </HBox>
                    <ComboBox fx:id="conditionCombo" maxWidth="Infinity" promptText="انتخاب کنید..."/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Submit row -->
        <HBox alignment="CENTER_LEFT" spacing="14">
            <Label fx:id="statusLabel" styleClass="status-danger" HBox.hgrow="ALWAYS"/>
            <Button fx:id="submitBtn" onAction="#handleSubmit" styleClass="btn-primary-lg"
                    prefWidth="190" text="ثبت آگهی">
                <graphic><FontIcon iconLiteral="fas-paper-plane" iconSize="15" iconColor="#ffffff"/></graphic>
            </Button>
        </HBox>

    </VBox>
</ScrollPane>
