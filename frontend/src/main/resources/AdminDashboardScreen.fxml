<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.aut.frontend.controller.AdminDashboardController"
            style="-fx-background-color: #0d0d0d;" nodeOrientation="RIGHT_TO_LEFT">
    <top>
        <BorderPane style="-fx-background-color: #242424; -fx-padding: 20;">
            <right><Label text="پنل مدیریت" textFill="WHITE"><font><Font name="System Bold" size="20"/></font></Label></right>
            <left><Button text="بازگشت" onAction="#goBack" style="-fx-background-color: transparent; -fx-border-color: #555; -fx-text-fill: #aaa; -fx-padding: 6 16;"/></left>
        </BorderPane>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-padding: 15;">
            <tabs>
                <Tab text="آمار">
                    <FlowPane fx:id="statsPane" hgap="15" vgap="15" style="-fx-padding: 20;"/>
                </Tab>
                <Tab text="همه آگهی‌ها">
                    <ScrollPane fitToWidth="true"><FlowPane fx:id="adminAdGrid" hgap="16" vgap="16" style="-fx-padding: 15; -fx-background-color: #0d0d0d;"/></ScrollPane>
                </Tab>
                <Tab text="کاربران">
                    <ListView fx:id="usersList"/>
                </Tab>
                <Tab text="دسته‌بندی‌ها">
                    <VBox spacing="10" style="-fx-padding: 15;">
                        <HBox spacing="10"><TextField fx:id="categoryNameField" promptText="نام دسته‌بندی" HBox.hgrow="ALWAYS"/><Button text="افزودن" onAction="#addCategory"/></HBox>
                        <ListView fx:id="categoriesList" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </Tab>
                <Tab text="شهرها">
                    <VBox spacing="10" style="-fx-padding: 15;">
                        <HBox spacing="10"><TextField fx:id="cityNameField" promptText="نام شهر" HBox.hgrow="ALWAYS"/><Button text="افزودن" onAction="#addCity"/></HBox>
                        <ListView fx:id="citiesList" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    <bottom><HBox style="-fx-padding: 10; -fx-background-color: #242424;"><Label fx:id="statusLabel" textFill="#ff5a5a"/></HBox></bottom>
</BorderPane>
