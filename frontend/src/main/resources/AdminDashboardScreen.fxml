<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.aut.frontend.controller.AdminDashboardController"
            stylesheets="@AdminDashboard.css" styleClass="admin-root" nodeOrientation="RIGHT_TO_LEFT">
    <top>
        <BorderPane styleClass="admin-header">
            <right>
                <VBox spacing="3">
                    <Label text="پنل مدیریت" styleClass="admin-title"/>
                    <Label text="مدیریت آگهی‌ها، کاربران و اطلاعات پایه" styleClass="admin-subtitle"/>
                </VBox>
            </right>
            <left>
                <Button text="بازگشت" onAction="#goBack" styleClass="admin-back-button">
                    <graphic><FontIcon iconLiteral="fas-arrow-left" iconSize="13" iconColor="#aaa"/></graphic>
                </Button>
            </left>
        </BorderPane>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" styleClass="admin-tabs">
            <tabs>
                <Tab text="آمار">
                    <ScrollPane fitToWidth="true" styleClass="admin-scroll">
                        <FlowPane fx:id="statsPane" hgap="16" vgap="16" styleClass="admin-content"/>
                    </ScrollPane>
                </Tab>
                <Tab text="همه آگهی‌ها">
                    <ScrollPane fitToWidth="true" styleClass="admin-scroll">
                        <FlowPane fx:id="adminAdGrid" hgap="16" vgap="16" styleClass="admin-content"/>
                    </ScrollPane>
                </Tab>
                <Tab text="کاربران">
                    <ListView fx:id="usersList" styleClass="admin-list"/>
                </Tab>
                <Tab text="دسته‌بندی‌ها">
                    <VBox spacing="14" styleClass="admin-content">
                        <HBox spacing="10">
                            <TextField fx:id="categoryNameField" promptText="نام دسته‌بندی جدید" styleClass="admin-input" HBox.hgrow="ALWAYS"/>
                            <Button text="افزودن" onAction="#addCategory" styleClass="admin-primary-button">
                                <graphic><FontIcon iconLiteral="fas-plus" iconSize="12" iconColor="white"/></graphic>
                            </Button>
                        </HBox>
                        <ListView fx:id="categoriesList" styleClass="admin-list" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </Tab>
                <Tab text="شهرها">
                    <VBox spacing="14" styleClass="admin-content">
                        <HBox spacing="10">
                            <TextField fx:id="cityNameField" promptText="نام شهر جدید" styleClass="admin-input" HBox.hgrow="ALWAYS"/>
                            <Button text="افزودن" onAction="#addCity" styleClass="admin-primary-button">
                                <graphic><FontIcon iconLiteral="fas-plus" iconSize="12" iconColor="white"/></graphic>
                            </Button>
                        </HBox>
                        <ListView fx:id="citiesList" styleClass="admin-list" VBox.vgrow="ALWAYS"/>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    <bottom>
        <HBox styleClass="admin-statusbar">
            <Label fx:id="statusLabel" styleClass="admin-status"/>
        </HBox>
    </bottom>
</BorderPane>
