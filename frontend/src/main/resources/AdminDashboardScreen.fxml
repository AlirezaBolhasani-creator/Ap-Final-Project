<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.aut.frontend.controller.AdminDashboardController"
            style="-fx-background-color: #0d0d0d;"
            nodeOrientation="RIGHT_TO_LEFT">

    <top>
        <BorderPane style="-fx-background-color: #242424; -fx-padding: 20;">
            <right>
                <Label text="پنل مدیریت - بررسی آگهی‌های در انتظار" textFill="WHITE" BorderPane.alignment="CENTER">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
            </right>
            <left>
                <Button onAction="#goBack" style="-fx-background-color: transparent; -fx-border-color: #555; -fx-border-radius: 5; -fx-text-fill: #aaa; -fx-padding: 5 15; -fx-cursor: hand;" text="بازگشت به صفحه اصلی" BorderPane.alignment="CENTER" />
            </left>
        </BorderPane>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 30;">

            <Label text="لیست آگهی‌های ثبت شده:" textFill="WHITE">
                <font><Font name="System Bold" size="16.0" /></font>
            </Label>

            <ScrollPane fitToWidth="true" style="-fx-background: #0d0d0d; -fx-background-color: #0d0d0d; -fx-border-color: #333;" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="adminAdGrid" hgap="16" vgap="16" style="-fx-padding: 10; -fx-background-color: #0d0d0d;"/>
            </ScrollPane>

        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: #242424;">
            <Label fx:id="statusLabel" text="در حال بارگذاری..." textFill="#ff5a5a"/>
        </HBox>
    </bottom>

</BorderPane>