<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<!--
    AdCard.fxml — marketplace ad card.
    Loaded via FXMLLoader inside MainViewController and populated
    with AdCardController.setData(...).
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="divar.aut.frontend.controller.AdCardController"
      fx:id="cardRoot"
      styleClass="ad-card"
      prefWidth="240"
      spacing="0"
      alignment="TOP_CENTER"
      style="-fx-cursor: hand;">

    <!-- ── Thumbnail ── -->
    <StackPane styleClass="ad-card-thumb">
        <ImageView fx:id="adImage"
                   fitWidth="240"
                   fitHeight="160"
                   preserveRatio="false"/>

        <!-- Category badge (bottom-right in RTL) -->
        <HBox alignment="BOTTOM_LEFT" styleClass="overlay-pad">
            <Label fx:id="photoCount" text="" styleClass="ad-card-category"/>
        </HBox>

        <!-- Condition chip (top-left in RTL) -->
        <HBox alignment="TOP_RIGHT" styleClass="overlay-pad">
            <Label fx:id="conditionLabel" text="نو" styleClass="ad-card-obadge"/>
        </HBox>
    </StackPane>

    <!-- ── Info ── -->
    <VBox styleClass="ad-card-info" spacing="6" VBox.vgrow="ALWAYS">

        <Label fx:id="adTitle"
               text="عنوان آگهی"
               styleClass="ad-card-title"
               wrapText="true"
               maxHeight="42"/>

        <Region VBox.vgrow="ALWAYS"/>

        <HBox alignment="CENTER_RIGHT" spacing="4">
            <Label fx:id="adPrice" text="۵۰۰٬۰۰۰" styleClass="ad-card-price"/>
            <Label text="تومان" styleClass="text-caption"/>
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="6">
            <Label fx:id="adTime"     text="لحظاتی پیش" styleClass="text-caption"/>
            <Label text="·"           styleClass="text-lo"/>
            <Label fx:id="adLocation" text="تهران"      styleClass="text-caption"/>
        </HBox>

    </VBox>

</VBox>
