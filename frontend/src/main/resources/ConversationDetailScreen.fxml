<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.aut.frontend.controller.ConversationDetailController"
            stylesheets="@theme.css"
            styleClass="chat-root"
            nodeOrientation="RIGHT_TO_LEFT">

    <top>
        <HBox styleClass="chat-header" alignment="CENTER_LEFT" spacing="12" nodeOrientation="LEFT_TO_RIGHT">
            <Button text="بازگشت به آگهی" onAction="#handleBackToAd" styleClass="btn btn-outline">
                <graphic>
                    <FontIcon iconLiteral="fas-arrow-right" iconSize="14" iconColor="#a9b8de"/>
                </graphic>
            </Button>
            <Button text="بازگشت به گفتگوها" onAction="#handleBack" styleClass="btn btn-outline">
                <graphic>
                    <FontIcon iconLiteral="fas-arrow-right" iconSize="14" iconColor="#a9b8de"/>
                </graphic>
            </Button>
            <Region HBox.hgrow="ALWAYS"/>
            <StackPane styleClass="detail-avatar">
                <FontIcon iconLiteral="fas-comments" iconSize="20" iconColor="#6b93ff"/>
            </StackPane>
            <Label fx:id="headerLabel" text="گفت‌وگو" styleClass="text-h3"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fx:id="messageScrollPane" fitToWidth="true" styleClass="chat-scroll">
            <VBox fx:id="messagesBox" spacing="10" styleClass="chat-messages"/>
        </ScrollPane>
    </center>

    <bottom>
        <VBox spacing="10" styleClass="chat-input-area">
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <TextField fx:id="messageField" promptText="پیام خود را بنویسید..." HBox.hgrow="ALWAYS"
                           onAction="#sendMessage"/>
                <Button text="ارسال" onAction="#sendMessage" styleClass="btn btn-primary">
                    <graphic><FontIcon iconLiteral="fas-paper-plane" iconSize="14" iconColor="#ffffff"/></graphic>
                </Button>
            </HBox>
            <Label fx:id="statusLabel" styleClass="status-danger"/>
        </VBox>
    </bottom>
</BorderPane>
