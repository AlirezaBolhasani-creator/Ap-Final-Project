<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.aut.frontend.controller.FavoritesController"
            stylesheets="@theme.css">

    <top>
        <VBox>
            <HBox styleClass="app-nav" alignment="CENTER_LEFT" spacing="12">
                <FontIcon iconLiteral="fas-heart" iconSize="22" iconColor="#fb6f6f"/>
                <Label text="علاقه‌مندی‌ها" styleClass="text-h2"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="بازگشت" styleClass="btn-outline" onAction="#goBack">
                    <graphic><FontIcon iconLiteral="fas-arrow-left" iconSize="14" iconColor="#a9b8de"/></graphic>
                </Button>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox spacing="0" styleClass="list-page">
                <Label text="آگهی‌هایی که ذخیره کردی اینجا نمایش داده می‌شوند" styleClass="list-sub"/>
                <FlowPane fx:id="favoritesGrid" hgap="20" vgap="20" prefWrapLength="820"/>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="12">
            <FontIcon iconLiteral="fas-circle" iconSize="7" iconColor="#34d399"/>
            <Label fx:id="statusLabel" text="در حال دریافت علاقه‌مندی‌ها..." styleClass="text-caption"/>
        </HBox>
    </bottom>
</BorderPane>
