<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="divar.aut.frontend.controller.RegisterController"
           stylesheets="@theme.css" styleClass="auth-backdrop"
           nodeOrientation="RIGHT_TO_LEFT">

    <VBox alignment="CENTER" spacing="0" maxWidth="560">
        <VBox styleClass="auth-card" alignment="CENTER" spacing="18" maxWidth="560">

            <Label text="دیوار" styleClass="brand-logo"/>
            <Label text="ساخت حساب جدید" styleClass="text-h2"/>

            <GridPane hgap="16" vgap="14" maxWidth="Infinity">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>
                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="نام و نام خانوادگی" styleClass="text-small"/>
                    <TextField fx:id="nameField" promptText="مثلاً علی رضایی" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="نام کاربری" styleClass="text-small"/>
                    <TextField fx:id="usernameField" promptText="نام کاربری" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="ایمیل" styleClass="text-small"/>
                    <TextField fx:id="emailField" promptText="example@mail.com" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="شماره موبایل" styleClass="text-small"/>
                    <TextField fx:id="phoneField" promptText="09xxxxxxxxx" maxWidth="Infinity"/>
                </VBox>
            </GridPane>

            <VBox spacing="6" maxWidth="Infinity" alignment="CENTER_LEFT">
                <Label text="رمز عبور" styleClass="text-small"/>
                <PasswordField fx:id="passwordField" promptText="رمز عبور" maxWidth="Infinity"/>
            </VBox>

            <Label fx:id="statusLabel" text="" styleClass="status-danger" wrapText="true"/>

            <Button text="ثبت نام" styleClass="btn btn-primary btn-lg" maxWidth="Infinity" onAction="#handleRegister" defaultButton="true"/>

            <Button text="بازگشت" styleClass="btn btn-ghost" onAction="#goWelcome">
                <graphic><FontIcon iconLiteral="fas-arrow-right" iconSize="14" iconColor="#a9b8de"/></graphic>
            </Button>
        </VBox>
    </VBox>
</StackPane>
