<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.aut.frontend.controller.AdDetailsController"
            stylesheets="@theme.css"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">

    <VBox spacing="20" styleClass="detail-page" nodeOrientation="RIGHT_TO_LEFT">

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button text="بازگشت" onAction="#handleBack" styleClass="btn-outline">
                <graphic>
                    <FontIcon iconLiteral="fas-arrow-right" iconSize="14" iconColor="#a9b8de"/>
                </graphic>
            </Button>
        </HBox>

        <!-- Two-column layout: Images (left) + Details (right) -->
        <HBox spacing="20" VBox.vgrow="ALWAYS" alignment="TOP_CENTER">

            <!-- LEFT: Image gallery -->
            <VBox fx:id="imageContainer" spacing="14" alignment="TOP_CENTER" styleClass="detail-hero" prefWidth="420">
                <StackPane styleClass="detail-main-frame" maxWidth="400" maxHeight="350">
                    <ImageView fx:id="mainImageView" fitWidth="400" fitHeight="350"
                               preserveRatio="true" smooth="true" cache="true"/>
                </StackPane>

                <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                            styleClass="detail-thumb-scroll" maxWidth="400" prefHeight="100">
                    <HBox fx:id="imageGalleryBox" styleClass="image-gallery-box"/>
                </ScrollPane>
            </VBox>

            <!-- RIGHT: Details -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">

                <!-- Title -->
                <Label fx:id="titleLabel" text="عنوان آگهی" styleClass="text-h1" wrapText="true"/>

                <!-- Price banner -->
                <HBox styleClass="detail-price-banner" alignment="CENTER_LEFT" spacing="8">
                    <FontIcon iconLiteral="fas-tag" iconSize="18" iconColor="#34d399"/>
                    <Label fx:id="priceLabel" text="۰" styleClass="detail-price"/>
                    <Label text="تومان" styleClass="text-small"/>
                </HBox>

                <!-- Meta chips -->
                <HBox spacing="12">
                    <VBox styleClass="meta-chip" spacing="6" HBox.hgrow="ALWAYS">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-map-marker-alt" iconSize="13" iconColor="#6b93ff"/>
                            <Label text="مکان" styleClass="meta-chip-label"/>
                        </HBox>
                        <Label fx:id="locationLabel" text="نامشخص" styleClass="meta-chip-value" wrapText="true"/>
                    </VBox>

                    <VBox styleClass="meta-chip" spacing="6" HBox.hgrow="ALWAYS">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-th-large" iconSize="13" iconColor="#6b93ff"/>
                            <Label text="دسته‌بندی" styleClass="meta-chip-label"/>
                        </HBox>
                        <Label fx:id="categoryLabel" text="نامشخص" styleClass="meta-chip-value" wrapText="true"/>
                    </VBox>

                    <VBox styleClass="meta-chip" spacing="6" HBox.hgrow="ALWAYS">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-box-open" iconSize="13" iconColor="#fbbf24"/>
                            <Label text="وضعیت کالا" styleClass="meta-chip-label"/>
                        </HBox>
                        <Label fx:id="conditionLabel" text="نامشخص" styleClass="meta-chip-value" wrapText="true"/>
                    </VBox>
                </HBox>

                <!-- Seller card -->
                <HBox styleClass="detail-seller" alignment="CENTER_RIGHT" spacing="14">
                    <StackPane styleClass="detail-avatar">
                        <FontIcon iconLiteral="fas-user" iconSize="22" iconColor="#6b93ff"/>
                    </StackPane>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="sellerNameLabel" text="فروشنده" styleClass="text-h3"/>
                    </VBox>
                    <Label fx:id="sellerRatingLabel" text="بدون امتیاز" styleClass="badge-warning"/>
                </HBox>

                <!-- Description -->
                <VBox spacing="8">
                    <Label text="توضیحات" styleClass="text-h3"/>
                    <VBox styleClass="detail-desc" minHeight="90">
                        <Label fx:id="descriptionLabel" wrapText="true" styleClass="detail-desc-text"/>
                    </VBox>
                </VBox>

                <!-- Comments -->
                <VBox spacing="10" fx:id="commentsSection" visible="false" managed="false">
                    <Label text="نظرات کاربران درباره فروشنده" styleClass="text-h3"/>
                    <VBox fx:id="commentsBox" spacing="8"/>
                </VBox>

                <Separator style="-fx-opacity: 0.08;"/>

                <!-- Viewer actions -->
                <HBox fx:id="viewerActionBox" styleClass="action-bar" spacing="12" alignment="CENTER_LEFT" visible="false" managed="false">
                    <Button fx:id="messageButton" text="پیام به فروشنده" onAction="#handleMessageSeller" styleClass="btn-primary">
                        <graphic><FontIcon iconLiteral="fas-comment-dots" iconSize="14" iconColor="#ffffff"/></graphic>
                    </Button>
                    <Button fx:id="ratingButton" text="ثبت امتیاز" onAction="#handleRateSeller" styleClass="btn-warning">
                        <graphic><FontIcon iconLiteral="fas-star" iconSize="14" iconColor="#fbbf24"/></graphic>
                    </Button>
                    <Button fx:id="favoriteButton" text="علاقه‌مندی" onAction="#handleAddFavorite" styleClass="btn-outline">
                        <graphic><FontIcon iconLiteral="fas-heart" iconSize="14" iconColor="#fb6f6f"/></graphic>
                    </Button>
                </HBox>

                <!-- Admin actions -->
                <HBox fx:id="adminActionBox" styleClass="action-bar" spacing="12" alignment="CENTER_LEFT" visible="false" managed="false">
                    <Button fx:id="approveButton" text="تایید آگهی" onAction="#handleApprove" styleClass="btn-success">
                        <graphic><FontIcon iconLiteral="fas-check" iconSize="14" iconColor="#34d399"/></graphic>
                    </Button>
                    <Button fx:id="rejectButton" text="رد کردن" onAction="#handleReject" styleClass="btn-danger">
                        <graphic><FontIcon iconLiteral="fas-times" iconSize="14" iconColor="#fb6f6f"/></graphic>
                    </Button>
                    <Button fx:id="adminDeleteButton" text="حذف آگهی" onAction="#handleAdminDelete" styleClass="btn-danger">
                        <graphic><FontIcon iconLiteral="fas-trash" iconSize="14" iconColor="#fb6f6f"/></graphic>
                    </Button>
                </HBox>

                <!-- Owner actions -->
                <HBox fx:id="ownerActionBox" styleClass="action-bar" spacing="12" alignment="CENTER_LEFT" visible="false" managed="false">
                    <Button fx:id="editButton" text="ویرایش" onAction="#handleEdit" styleClass="btn-info">
                        <graphic><FontIcon iconLiteral="fas-edit" iconSize="14" iconColor="#60a5fa"/></graphic>
                    </Button>
                    <Button fx:id="markAsSoldButton" text="فروخته شد" onAction="#handleMarkAsSold" styleClass="btn-warning">
                        <graphic><FontIcon iconLiteral="fas-check-circle" iconSize="14" iconColor="#fbbf24"/></graphic>
                    </Button>
                    <Button fx:id="deleteButton" text="حذف" onAction="#handleDelete" styleClass="btn-danger">
                        <graphic><FontIcon iconLiteral="fas-trash" iconSize="14" iconColor="#fb6f6f"/></graphic>
                    </Button>
                </HBox>

                <Label fx:id="statusLabel" styleClass="status-danger"/>

            </VBox>

        </HBox>

    </VBox>
</ScrollPane>
