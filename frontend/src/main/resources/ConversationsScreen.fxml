<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="divar.aut.frontend.controller.ConversationsController"
            stylesheets="@theme.css">

    <top>
        <HBox styleClass="app-nav" alignment="CENTER_LEFT" spacing="12">
            <FontIcon iconLiteral="fas-comments" iconSize="22" iconColor="#6b93ff"/>
            <Label text="گفت‌وگوها" styleClass="text-h2"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="بازگشت" styleClass="btn-outline" onAction="#goBack">
                <graphic><FontIcon iconLiteral="fas-arrow-left" iconSize="14" iconColor="#a9b8de"/></graphic>
            </Button>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <VBox spacing="0" styleClass="list-page">
                <Label text="پیام‌های خریداران و فروشندگان اینجاست" styleClass="list-sub"/>
                <VBox fx:id="conversationList" spacing="12"/>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="12">
            <FontIcon iconLiteral="fas-circle" iconSize="7" iconColor="#34d399"/>
            <Label fx:id="statusLabel" text="در حال دریافت گفت‌وگوها..." styleClass="text-caption"/>
        </HBox>
    </bottom>
</BorderPane>
